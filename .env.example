# Copy to .env and fill in. These names match the GitHub Actions Secrets exactly.
# Local testing reads .env; in CI these come from GitHub Secrets.

# --- Google Ads (Step 1) ---
GOOGLE_ADS_DEVELOPER_TOKEN=        # MCC > API Center (needs Basic access for live data)
GOOGLE_ADS_CLIENT_ID=              # GCP OAuth client (Desktop app)
GOOGLE_ADS_CLIENT_SECRET=          # GCP OAuth client
GOOGLE_ADS_REFRESH_TOKEN=          # from generate_refresh_token.py (authorized as jim@airops.com)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=      # the new MCC ID, digits only, no dashes
GOOGLE_ADS_CUSTOMER_ID=2965557823  # AirOps serving account (USD, America/Los_Angeles)

# --- Added in later build steps ---
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=                  # Incoming Webhook bound to #airops-paidads-shared-main (private — creator must be a member)
HUBSPOT_API_KEY=

# --- Search Term Intelligence tuning (optional; these are the defaults) ---
# An intent-mismatch is only flagged if, over the last 7 days, the term spent at
# least this much AND got at least this many clicks ("a lot of money and clicks").
MISMATCH_MIN_COST=50
MISMATCH_MIN_CLICKS=5
# CLAUDE_MODEL=claude-sonnet-4-6
